{
  "project": {
    "title": "Karma CLI Parsing SDK (JavaScript)",
    "id": "kcli_javascript"
  },
  "git": {
    "url": "https://github.com/QM-Code/kcli-javascript",
    "auth": "git@github.com:QM-Code/kcli-javascript.git"
  },
  "javascript": {
    "package": "kcli",
    "sdk_dir": "src",
    "test_globs": [
      "tests/*.js",
      "demo/tests/*.js"
    ],
    "demos": {
      "bootstrap": {
        "entry": "demo/bootstrap/main.js"
      },
      "exe/core": {
        "entry": "demo/exe/core/main.js",
        "output": "test"
      },
      "exe/omega": {
        "entry": "demo/exe/omega/main.js",
        "output": "test"
      }
    }
  },
  "build": {
    "demos": [
      "bootstrap",
      "exe/core",
      "exe/omega"
    ],
    "defaults": {
      "demos": [
        "bootstrap",
        "exe/core",
        "exe/omega"
      ]
    }
  }
}
